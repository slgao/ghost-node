# ─── Control Plane ───────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=debug   # debug | release

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=vpnplatform
DATABASE_PASSWORD=changeme_dev
DATABASE_DBNAME=vpnplatform
DATABASE_SSLMODE=disable
DATABASE_MAX_CONNS=25

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h   # 7 days

# ─── gRPC (control plane ↔ node agent) ───────────────────────────────────────
GRPC_HOST=0.0.0.0
GRPC_PORT=9090
GRPC_CERT_FILE=/etc/vpnplatform/tls/server.crt
GRPC_KEY_FILE=/etc/vpnplatform/tls/server.key
GRPC_CA_FILE=/etc/vpnplatform/tls/ca.crt

# ─── Node Agent ──────────────────────────────────────────────────────────────
AGENT_CONTROL_PLANE_ADDR=control-plane:9090
AGENT_NODE_ID=
AGENT_XRAY_BIN=/usr/local/bin/xray
AGENT_HYSTERIA2_BIN=/usr/local/bin/hysteria

# ─── Observability ───────────────────────────────────────────────────────────
PROMETHEUS_NAMESPACE=vpnplatform
LOG_LEVEL=info   # debug | info | warn | error
