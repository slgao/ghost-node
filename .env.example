# ── HOW TO USE ────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is in .gitignore and will NEVER be committed to GitHub.
# .env.example is a safe template with no real secrets — it IS committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=vpnplatform
POSTGRES_PASSWORD=change_me
POSTGRES_DB=vpnplatform

# ── JWT (use a long random string in production) ──────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret

# ── Database (control plane) ──────────────────────────────────────────────────
DATABASE_USER=vpnplatform
DATABASE_PASSWORD=change_me
DATABASE_DBNAME=vpnplatform
