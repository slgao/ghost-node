{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "HTTP Traffic",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table" }, "tooltip": { "mode": "multi" } },
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(vpnplatform_http_requests_total[1m])) by (method, path)",
          "legendFormat": "{{method}} {{path}}",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "title": "HTTP P99 Latency by Path",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(vpnplatform_http_request_duration_seconds_bucket[1m])) by (le, path))",
          "legendFormat": "p99 {{path}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(vpnplatform_http_request_duration_seconds_bucket[1m])) by (le, path))",
          "legendFormat": "p50 {{path}}",
          "refId": "B"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 9 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Total Requests (5m)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(increase(vpnplatform_http_requests_total[5m]))",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "red", "value": 0.05 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 9 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "HTTP Error Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(vpnplatform_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(vpnplatform_http_requests_total[5m]))",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 200,
      "title": "Authentication",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 5,
      "title": "Auth Events per Minute",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(vpnplatform_auth_events_total[1m])) by (event, success)",
          "legendFormat": "{{event}} (success={{success}})",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 20 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 14 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Failed Logins (5m)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(increase(vpnplatform_auth_events_total{event=\"login\",success=\"false\"}[5m]))",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "blue", "value": null }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 14 },
      "id": 7,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Registered Users",
      "type": "stat",
      "targets": [
        {
          "expr": "vpnplatform_users_registered_total",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 300,
      "title": "VPN Sessions & Traffic",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 500 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 23 },
      "id": 8,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Active VPN Sessions",
      "type": "stat",
      "targets": [
        { "expr": "vpnplatform_vpn_active_sessions", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "unit": "Bps"
        }
      },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 23 },
      "id": 9,
      "title": "VPN Bandwidth",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(vpnplatform_traffic_bytes_total{direction=\"in\"}[1m])",
          "legendFormat": "Inbound",
          "refId": "A"
        },
        {
          "expr": "rate(vpnplatform_traffic_bytes_total{direction=\"out\"}[1m])",
          "legendFormat": "Outbound",
          "refId": "B"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 400,
      "title": "Go Runtime",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 32 },
      "id": 10,
      "title": "Goroutines",
      "type": "timeseries",
      "targets": [
        { "expr": "go_goroutines{job=\"control-plane\"}", "legendFormat": "goroutines", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 32 },
      "id": 11,
      "title": "Heap Memory",
      "type": "timeseries",
      "targets": [
        { "expr": "go_memstats_heap_alloc_bytes{job=\"control-plane\"}", "legendFormat": "heap alloc", "refId": "A" },
        { "expr": "go_memstats_heap_sys_bytes{job=\"control-plane\"}", "legendFormat": "heap sys", "refId": "B" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 32 },
      "id": 12,
      "title": "GC Pause Duration",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(go_gc_duration_seconds_sum{job=\"control-plane\"}[1m]) / rate(go_gc_duration_seconds_count{job=\"control-plane\"}[1m])",
          "legendFormat": "avg GC pause",
          "refId": "A"
        }
      ]
    }

  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["vpn", "platform"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "VPN Platform Overview",
  "uid": "vpnplatform-overview",
  "version": 1
}
